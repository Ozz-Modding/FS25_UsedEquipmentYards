<?xml version="1.0" encoding="iso-8859-1"?>

<i3D name="saleZone.i3d" version="1.6" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://i3d.giants.ch/schema/i3d-1.6.xsd">
  <Asset>
    <Export program="GIANTS Editor 64bit" version="10.0.11"/>
  </Asset>

  <Files>
    <File fileId="5" filename="$data/shaders/placeableShader.xml"/>
    <File fileId="2" filename="$data/shared/warningStripes_diffuse.dds"/>
    <File fileId="3" filename="$data/shared/warningStripes_normal.dds"/>
    <File fileId="4" filename="$data/shared/warningStripes_specular.dds"/>
  </Files>


  <Materials>
    <Material name="lambert1" materialId="5" diffuseColor="0.494118 0.494118 0.494118 1">
    </Material>
    <Material name="warningStripes_mat" materialId="6" customShaderId="5">
      <Texture fileId="2"/>
      <Normalmap fileId="3"/>
      <Glossmap fileId="4"/>
      <CustomParameter name="snowScale" value="0"/>
    </Material>
  </Materials>


  <Shapes externalShapesFile="saleZone.i3d.shapes">
  </Shapes>

  <Scene>
    <TransformGroup name="saleZone" clipDistance="150" nodeId="11">
      <TransformGroup name="testAreas" nodeId="12">
        <TransformGroup name="testArea1Start" translation="-4.5 0 -3.5" nodeId="13">
          <TransformGroup name="testArea1End" translation="9 2 7" nodeId="14"/>
