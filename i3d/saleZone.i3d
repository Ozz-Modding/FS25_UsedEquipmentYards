        <TransformGroup name="clearArea1Height" translation="0 0 7" nodeId="17"/>
      </TransformGroup>
      <TransformGroup name="levelAreaStart" translation="-5 0 -4" nodeId="18">
        <TransformGroup name="levelAreaWidth" translation="10 0 0" nodeId="19"/>
        <TransformGroup name="levelAreaHeight" translation="0 0 8" nodeId="20"/>
      </TransformGroup>
      <TransformGroup name="tipOcclusionUpdateAreas" nodeId="21">
        <TransformGroup name="tipOcclusionUpdateArea1Start" translation="-5.5 0 -4.5" nodeId="22">
          <TransformGroup name="tipOcclusionUpdateArea1End" translation="11 0 9" nodeId="23"/>
