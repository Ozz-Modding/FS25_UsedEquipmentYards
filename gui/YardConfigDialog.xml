<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI onOpen="onOpen" onClose="onClose" onCreate="onCreate">
    <GuiElement profile="newLayer"/>
    <Bitmap profile="dialogFullscreenBg" id="dialogBg"/>
    <GuiElement profile="fs25_dialogBg" id="dialogElement" size="1400px 720px">
        <ThreePartBitmap profile="fs25_dialogBgMiddle"/>
        <ThreePartBitmap profile="fs25_dialogBgTop"/>
        <ThreePartBitmap profile="fs25_dialogBgBottom"/>
        <GuiElement profile="fs25_dialogContentContainer">
            <Text profile="dialogTitle" text="$l10n_uey_config_title" id="dialogTitleElement" position="0px -15px"/>

            <!-- ======== LEFT COLUMN: Core Settings ======== -->
            <GuiElement position="40px 0px" size="350px 580px">
                <Text profile="ueyColumnHeader" text="$l10n_uey_config_settings_header" position="0px 0px" size="350px 24px"/>

                <!-- Yard Name -->
                <Text profile="ueySettingLabel" text="$l10n_uey_config_yardName" position="0px -28px" size="350px 24px"/>
                <TextInput profile="ueyTextInput" id="yardNameInput" position="0px -52px" size="310px 32px"
                    onEnterPressed="onNameEnterPressed" onEscPressed="onNameEscPressed" enterWhenClickOutside="true"
                    applyProfanityFilter="false" imeTitle="" imeDescription="" imePlaceholder="">
                    <Bitmap profile="fs25_dialogTextInputIconBox">
                        <Bitmap profile="fs25_dialogTextInputIcon"/>
                    </Bitmap>
                </TextInput>

                <!-- Quality -->
                <Text profile="ueySettingLabel" text="$l10n_uey_config_quality" position="0px -92px" size="350px 24px"/>
                <Text profile="ueySettingDesc2Line" text="$l10n_uey_config_quality_desc" position="0px -116px" size="350px 36px"/>
                <MultiTextOption profile="ueyMultiTextOption" id="qualityOption"
                    position="0px -156px" size="350px 40px" onClick="onQualityChanged"/>

                <!-- Dirtiness -->
                <Text profile="ueySettingLabel" text="$l10n_uey_config_dirtiness" position="0px -208px" size="350px 24px"/>
                <Text profile="ueySettingDesc" text="$l10n_uey_config_dirtiness_desc" position="0px -232px" size="350px 20px"/>
                <MultiTextOption profile="ueyMultiTextOption" id="dirtinessOption"
                    position="0px -256px" size="350px 40px" onClick="onDirtinessChanged"/>

                <!-- Working Width -->
                <Text profile="ueySettingLabel" text="$l10n_uey_config_workingWidth" position="0px -308px" size="350px 24px"/>
                <Text profile="ueySettingDesc" text="$l10n_uey_config_workingWidth_desc" position="0px -332px" size="350px 20px"/>

                <Text profile="ueyWeightLabel" text="$l10n_uey_config_minWorkingWidth" position="0px -360px" size="130px 26px"/>
                <MultiTextOption profile="ueyMultiTextOption" id="minWorkingWidthOption"
                    position="130px -356px" size="210px 32px" onClick="onMinWorkingWidthChanged"/>

                <Text profile="ueyWeightLabel" text="$l10n_uey_config_maxWorkingWidth" position="0px -394px" size="130px 26px"/>
                <MultiTextOption profile="ueyMultiTextOption" id="maxWorkingWidthOption"
                    position="130px -390px" size="210px 32px" onClick="onMaxWorkingWidthChanged"/>

                <!-- Max Price -->
                <Text profile="ueySettingLabel" text="$l10n_uey_config_maxPrice" position="0px -434px" size="350px 24px"/>
                <Text profile="ueySettingDesc" text="$l10n_uey_config_maxPrice_desc" position="0px -458px" size="350px 20px"/>
                <MultiTextOption profile="ueyMultiTextOption" id="maxPriceOption"
                    position="0px -482px" size="350px 40px" onClick="onMaxPriceChanged"/>
            </GuiElement>

            <!-- ======== MIDDLE COLUMN: Category Weights ======== -->
            <GuiElement position="420px -18px" size="460px 600px">
                <Text profile="ueyColumnHeader" text="$l10n_uey_config_weights_header" position="0px 0px" size="460px 24px"/>
                <Text profile="ueySettingDesc" text="$l10n_uey_config_weights_desc" position="0px -22px" size="460px 18px"/>

                <ScrollingLayout position="0px 46px" size="460px 490px" flowDirection="vertical" id="weightScrollLayout">
                    <GuiElement profile="ueyWeightRow" size="460px 26px" id="weightRowTemplate" visible="false">
                        <Text profile="ueyWeightLabel" size="230px 26px" id="weightRowLabel"/>
                        <MultiTextOption profile="ueyMultiTextOption" position="230px 0px" size="220px 26px" id="weightRowOption" onClick="onWeightChanged"/>
                    </GuiElement>
                </ScrollingLayout>
            </GuiElement>

            <!-- ======== RIGHT COLUMN: Brands ======== -->
            <GuiElement position="910px -18px" size="460px 600px">
                <Text profile="ueyColumnHeader" text="$l10n_uey_config_brands_header" position="0px 0px" size="460px 24px"/>
                <Text profile="ueySettingDesc" text="$l10n_uey_config_brands_desc" position="0px -22px" size="460px 18px"/>

                <ScrollingLayout position="0px 46px" size="460px 490px" flowDirection="vertical" id="brandScrollLayout">
                    <GuiElement profile="ueyWeightRow" size="460px 26px" id="brandRowTemplate" visible="false">
                        <Text profile="ueyWeightLabel" size="230px 26px" id="brandRowLabel"/>
                        <MultiTextOption profile="ueyMultiTextOption" position="230px 0px" size="220px 26px" id="brandRowOption" onClick="onBrandChanged"/>
                    </GuiElement>
                </ScrollingLayout>
            </GuiElement>
        </GuiElement>

        <!-- Buttons -->
        <BoxLayout profile="fs25_dialogButtonBox" size="1200px 60px">
            <Button profile="buttonExtra1" text="$l10n_uey_config_clearWeights" onClick="onClickClearWeights"/>
            <Bitmap profile="fs25_dialogButtonBoxSeparator"/>
            <Button profile="buttonActivate" text="$l10n_uey_config_allBrands" onClick="onClickAllBrands"/>
            <Bitmap profile="fs25_dialogButtonBoxSeparator"/>
            <Button profile="buttonCancel" text="$l10n_uey_config_clearBrands" onClick="onClickClearBrands"/>
            <Bitmap profile="fs25_dialogButtonBoxSeparator"/>
            <Button profile="buttonOK" text="$l10n_uey_config_apply" onClick="onClickApply" id="applyButton"/>
            <Bitmap profile="fs25_dialogButtonBoxSeparator"/>
            <Button profile="buttonBack" text="$l10n_uey_config_close" onClick="onClickClose"/>
        </BoxLayout>
    </GuiElement>
</GUI>
