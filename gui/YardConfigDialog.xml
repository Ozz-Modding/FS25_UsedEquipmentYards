<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI onOpen="onOpen" onClose="onClose" onCreate="onCreate">
    <GuiElement profile="newLayer"/>
    <Bitmap profile="dialogFullscreenBg" id="dialogBg"/>
    <GuiElement profile="fs25_dialogBg" id="dialogElement" size="1000px 720px">
        <ThreePartBitmap profile="fs25_dialogBgMiddle"/>
        <ThreePartBitmap profile="fs25_dialogBgTop"/>
        <ThreePartBitmap profile="fs25_dialogBgBottom"/>
        <GuiElement profile="fs25_dialogContentContainer">
            <Text profile="dialogTitle" text="$l10n_uey_config_title" id="dialogTitleElement" position="0px -15px"/>

            <!-- ======== LEFT COLUMN: Core Settings ======== -->
            <GuiElement position="40px -18px" size="420px 580px">

                <!-- Quality -->
                <Text profile="ueySettingLabel" text="$l10n_uey_config_quality" position="0px 0px" size="400px 24px"/>
                <Text profile="ueySettingDesc" text="$l10n_uey_config_quality_desc" position="0px -24px" size="400px 50px"/>
                <MultiTextOption profile="ueyMultiTextOption" id="qualityOption"
                    position="0px -78px" size="400px 40px" onClick="onQualityChanged"/>

                <!-- Dirtiness -->
                <Text profile="ueySettingLabel" text="$l10n_uey_config_dirtiness" position="0px -140px" size="400px 24px"/>
                <Text profile="ueySettingDesc" text="$l10n_uey_config_dirtiness_desc" position="0px -164px" size="400px 50px"/>
                <MultiTextOption profile="ueyMultiTextOption" id="dirtinessOption"
                    position="0px -218px" size="400px 40px" onClick="onDirtinessChanged"/>

            </GuiElement>

            <!-- ======== RIGHT COLUMN: Category Weights ======== -->
            <GuiElement position="500px -18px" size="460px 600px">
                <Text profile="ueyColumnHeader" text="$l10n_uey_config_weights_header" position="0px 0px" size="460px 24px"/>
                <Text profile="ueySettingDesc" text="$l10n_uey_config_weights_desc" position="0px -22px" size="460px 18px"/>

                <!-- Scrollable weight rows — height smaller than content to enable scroll -->
                <ScrollingLayout position="0px 46px" size="460px 490px" flowDirection="vertical">

                    <GuiElement profile="ueyWeightRow" size="460px 26px">
                        <Text profile="ueyWeightLabel" text="$l10n_uey_cat_TRACTORSS" size="230px 26px"/>
                        <MultiTextOption profile="ueyMultiTextOption" id="weightTRACTORSS" position="230px 0px" size="220px 26px" onClick="onWeightChanged"/>
                    </GuiElement>

                    <GuiElement profile="ueyWeightRow" size="460px 26px">
                        <Text profile="ueyWeightLabel" text="$l10n_uey_cat_TRACTORSM" size="230px 26px"/>
                        <MultiTextOption profile="ueyMultiTextOption" id="weightTRACTORSM" position="230px 0px" size="220px 26px" onClick="onWeightChanged"/>
                    </GuiElement>

                    <GuiElement profile="ueyWeightRow" size="460px 26px">
                        <Text profile="ueyWeightLabel" text="$l10n_uey_cat_TRACTORSL" size="230px 26px"/>
                        <MultiTextOption profile="ueyMultiTextOption" id="weightTRACTORSL" position="230px 0px" size="220px 26px" onClick="onWeightChanged"/>
                    </GuiElement>

                    <GuiElement profile="ueyWeightRow" size="460px 26px">
                        <Text profile="ueyWeightLabel" text="$l10n_uey_cat_TELELOADERS" size="230px 26px"/>
                        <MultiTextOption profile="ueyMultiTextOption" id="weightTELELOADERS" position="230px 0px" size="220px 26px" onClick="onWeightChanged"/>
                    </GuiElement>

                    <GuiElement profile="ueyWeightRow" size="460px 26px">
                        <Text profile="ueyWeightLabel" text="$l10n_uey_cat_WHEELLOADERSM" size="230px 26px"/>
                        <MultiTextOption profile="ueyMultiTextOption" id="weightWHEELLOADERSM" position="230px 0px" size="220px 26px" onClick="onWeightChanged"/>
                    </GuiElement>

                    <GuiElement profile="ueyWeightRow" size="460px 26px">
                        <Text profile="ueyWeightLabel" text="$l10n_uey_cat_WHEELLOADERSL" size="230px 26px"/>
                        <MultiTextOption profile="ueyMultiTextOption" id="weightWHEELLOADERSL" position="230px 0px" size="220px 26px" onClick="onWeightChanged"/>
                    </GuiElement>

                    <GuiElement profile="ueyWeightRow" size="460px 26px">
                        <Text profile="ueyWeightLabel" text="$l10n_uey_cat_SKIDSTEERS" size="230px 26px"/>
                        <MultiTextOption profile="ueyMultiTextOption" id="weightSKIDSTEERS" position="230px 0px" size="220px 26px" onClick="onWeightChanged"/>
                    </GuiElement>

                    <GuiElement profile="ueyWeightRow" size="460px 26px">
                        <Text profile="ueyWeightLabel" text="$l10n_uey_cat_COMBINECUTTERS" size="230px 26px"/>
                        <MultiTextOption profile="ueyMultiTextOption" id="weightCOMBINECUTTERS" position="230px 0px" size="220px 26px" onClick="onWeightChanged"/>
                    </GuiElement>

                    <GuiElement profile="ueyWeightRow" size="460px 26px">
                        <Text profile="ueyWeightLabel" text="$l10n_uey_cat_HARVESTERS" size="230px 26px"/>
                        <MultiTextOption profile="ueyMultiTextOption" id="weightHARVESTERS" position="230px 0px" size="220px 26px" onClick="onWeightChanged"/>
                    </GuiElement>

                    <GuiElement profile="ueyWeightRow" size="460px 26px">
                        <Text profile="ueyWeightLabel" text="$l10n_uey_cat_FORAGEHARVESTERS" size="230px 26px"/>
                        <MultiTextOption profile="ueyMultiTextOption" id="weightFORAGEHARVESTERS" position="230px 0px" size="220px 26px" onClick="onWeightChanged"/>
                    </GuiElement>

                    <GuiElement profile="ueyWeightRow" size="460px 26px">
                        <Text profile="ueyWeightLabel" text="$l10n_uey_cat_SPRAYERS" size="230px 26px"/>
                        <MultiTextOption profile="ueyMultiTextOption" id="weightSPRAYERS" position="230px 0px" size="220px 26px" onClick="onWeightChanged"/>
                    </GuiElement>

                    <GuiElement profile="ueyWeightRow" size="460px 26px">
                        <Text profile="ueyWeightLabel" text="$l10n_uey_cat_FERTILIZERSPREAD" size="230px 26px"/>
                        <MultiTextOption profile="ueyMultiTextOption" id="weightFERTILIZERSPREAD" position="230px 0px" size="220px 26px" onClick="onWeightChanged"/>
                    </GuiElement>

                    <GuiElement profile="ueyWeightRow" size="460px 26px">
                        <Text profile="ueyWeightLabel" text="$l10n_uey_cat_SOWINGMACHINES" size="230px 26px"/>
                        <MultiTextOption profile="ueyMultiTextOption" id="weightSOWINGMACHINES" position="230px 0px" size="220px 26px" onClick="onWeightChanged"/>
                    </GuiElement>

                    <GuiElement profile="ueyWeightRow" size="460px 26px">
                        <Text profile="ueyWeightLabel" text="$l10n_uey_cat_PLOWS" size="230px 26px"/>
                        <MultiTextOption profile="ueyMultiTextOption" id="weightPLOWS" position="230px 0px" size="220px 26px" onClick="onWeightChanged"/>
                    </GuiElement>

                    <GuiElement profile="ueyWeightRow" size="460px 26px">
                        <Text profile="ueyWeightLabel" text="$l10n_uey_cat_CULTIVATORS" size="230px 26px"/>
                        <MultiTextOption profile="ueyMultiTextOption" id="weightCULTIVATORS" position="230px 0px" size="220px 26px" onClick="onWeightChanged"/>
                    </GuiElement>

                    <GuiElement profile="ueyWeightRow" size="460px 26px">
                        <Text profile="ueyWeightLabel" text="$l10n_uey_cat_MOWERS" size="230px 26px"/>
                        <MultiTextOption profile="ueyMultiTextOption" id="weightMOWERS" position="230px 0px" size="220px 26px" onClick="onWeightChanged"/>
                    </GuiElement>

                    <GuiElement profile="ueyWeightRow" size="460px 26px">
                        <Text profile="ueyWeightLabel" text="$l10n_uey_cat_TEDDERS" size="230px 26px"/>
                        <MultiTextOption profile="ueyMultiTextOption" id="weightTEDDERS" position="230px 0px" size="220px 26px" onClick="onWeightChanged"/>
                    </GuiElement>

                    <GuiElement profile="ueyWeightRow" size="460px 26px">
                        <Text profile="ueyWeightLabel" text="$l10n_uey_cat_WINDROWERS" size="230px 26px"/>
                        <MultiTextOption profile="ueyMultiTextOption" id="weightWINDROWERS" position="230px 0px" size="220px 26px" onClick="onWeightChanged"/>
                    </GuiElement>

                    <GuiElement profile="ueyWeightRow" size="460px 26px">
                        <Text profile="ueyWeightLabel" text="$l10n_uey_cat_BALERS" size="230px 26px"/>
                        <MultiTextOption profile="ueyMultiTextOption" id="weightBALERS" position="230px 0px" size="220px 26px" onClick="onWeightChanged"/>
                    </GuiElement>

                    <GuiElement profile="ueyWeightRow" size="460px 26px">
                        <Text profile="ueyWeightLabel" text="$l10n_uey_cat_TRAILERS" size="230px 26px"/>
                        <MultiTextOption profile="ueyMultiTextOption" id="weightTRAILERS" position="230px 0px" size="220px 26px" onClick="onWeightChanged"/>
                    </GuiElement>

                </ScrollingLayout>
            </GuiElement>
        </GuiElement>

        <!-- Buttons -->
        <BoxLayout profile="fs25_dialogButtonBox" size="600px 60px">
            <Button profile="buttonExtra1" text="$l10n_uey_config_apply" onClick="onClickApply" id="applyButton"/>
            <Bitmap profile="fs25_dialogButtonBoxSeparator"/>
            <Button profile="buttonBack" text="$l10n_uey_config_close" onClick="onClickClose"/>
        </BoxLayout>
    </GuiElement>
</GUI>
