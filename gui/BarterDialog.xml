<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI onOpen="onOpen" onClose="onClose" onCreate="onCreate">
    <GuiElement profile="newLayer"/>
    <Bitmap profile="dialogFullscreenBg" id="dialogBg"/>
    <GuiElement profile="fs25_dialogBg" id="dialogElement" size="800px 630px">
        <ThreePartBitmap profile="fs25_dialogBgMiddle"/>
        <ThreePartBitmap profile="fs25_dialogBgTop"/>
        <ThreePartBitmap profile="fs25_dialogBgBottom"/>
        <GuiElement profile="fs25_dialogContentContainer">
            <Text profile="dialogTitle" text="" id="dialogTitleElement" position="0px -10px"/>

            <!-- ======== ROW 1: Vehicle Info ======== -->
            <GuiElement profile="ueySection" position="40px -50px" size="720px 100px">
                <Text profile="ueyColumnHeader" text="$l10n_uey_barter_vehicleInfo" position="0px 0px" size="720px 22px"/>

                <Text profile="ueyWeightLabel" text="$l10n_uey_barter_brand"  position="10px -34px"   size="90px 20px"/>
                <Text profile="ueySettingLabel" text="" id="brandText"        position="100px -34px"  size="200px 20px"/>

                <Text profile="ueyWeightLabel" text="$l10n_uey_barter_owners" position="320px -34px"  size="90px 20px"/>
                <Text profile="ueySettingLabel" text="" id="ownersText"       position="410px -34px"  size="100px 20px"/>

                <Text profile="ueyWeightLabel" text="$l10n_uey_barter_hours"  position="10px -54px"   size="90px 20px"/>
                <Text profile="ueySettingLabel" text="" id="hoursText"        position="100px -54px"  size="200px 20px"/>

                <Text profile="ueyWeightLabel" text="$l10n_uey_barter_damage" position="320px -54px"  size="90px 20px"/>
                <Text profile="ueySettingLabel" text="" id="damageText"       position="410px -54px"  size="100px 20px"/>

                <Text profile="ueyWeightLabel" text="$l10n_uey_barter_wear"   position="10px -74px"   size="90px 20px"/>
                <Text profile="ueySettingLabel" text="" id="wearText"         position="100px -74px"  size="200px 20px"/>
            </GuiElement>

            <!-- ======== ROW 2: Specifications (horizontal wrap, scrollable) ======== -->
            <GuiElement profile="ueySection" position="40px -170px" size="720px 120px">
                <Text profile="ueyColumnHeader" text="$l10n_uey_barter_specs" position="0px 0px" size="720px 22px"/>
                <ScrollingLayout position="0px -24px" size="720px 90px" flowDirection="horizontal" numFlows="3" id="attributesLayout">
                    <GuiElement profile="fs25_itemDetailsTemplateBox" name="detailTemplate" id="attrTemplate" visible="false">
                        <Bitmap profile="fs25_itemDetailsIcon" name="icon"/>
                        <Text profile="fs25_itemDetailsText" text="" name="text" textAutoWidth="true"/>
                    </GuiElement>
                </ScrollingLayout>
            </GuiElement>

            <!-- ======== ROW 3: Barter Controls ======== -->
            <GuiElement profile="ueySection" position="40px -320px" size="720px 160px">
                <Text profile="ueyColumnHeader" text="$l10n_uey_barter_header" position="0px 0px" size="720px 22px"/>

                <Text profile="ueyWeightLabel" text="$l10n_uey_barter_askingPrice" position="0px -26px" size="140px 22px"/>
                <Text profile="ueySettingLabel" text="" id="askingPriceText"        position="140px -26px" size="200px 22px"/>

                <Text profile="ueyWeightLabel" text="$l10n_uey_credit_label"       position="380px -26px" size="120px 22px"/>
                <Text profile="ueySettingLabel" text="" id="creditBalanceText"      position="500px -26px" size="200px 22px"/>

                <Text profile="ueyWeightLabel" text="$l10n_uey_barter_yourOffer"   position="0px -52px" size="140px 22px"/>
                <MultiTextOption profile="ueyMultiTextOption" id="offerOption"
                    position="140px -48px" size="300px 32px" onClick="onOfferChanged"/>

                <Text profile="ueySettingDesc" text="" id="resultText"   position="0px -88px" size="720px 26px"/>
                <Text profile="ueySettingDesc" text="" id="chancesText"  position="0px -114px" size="720px 22px"/>
            </GuiElement>
        </GuiElement>

        <!-- Buttons -->
        <BoxLayout profile="fs25_dialogButtonBox" size="760px 60px">
            <Button profile="buttonActivate" text="$l10n_uey_barter_makeOffer" onClick="onClickMakeOffer" id="makeOfferButton"/>
            <Bitmap profile="fs25_dialogButtonBoxSeparator"/>
            <Button profile="buttonOK" text="$l10n_uey_barter_buyNow" onClick="onClickBuyNow" id="buyNowButton"/>
            <Bitmap profile="fs25_dialogButtonBoxSeparator"/>
            <Button profile="buttonExtra1" text="$l10n_uey_barter_testDrive" onClick="onClickTestDrive" id="testDriveButton"/>
            <Bitmap profile="fs25_dialogButtonBoxSeparator"/>
            <Button profile="buttonBack" text="$l10n_uey_config_close" onClick="onClickClose"/>
        </BoxLayout>
    </GuiElement>
</GUI>
