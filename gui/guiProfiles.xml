<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUIProfiles>

    <!-- Column header (e.g. "Category Weights") -->
    <Profile name="ueyColumnHeader" extends="baseReference" with="anchorTopLeft">
        <textBold value="true"/>
        <textSize value="20px"/>
        <textAlignment value="left"/>
        <textColor value="$preset_fs25_colorMainHighlight"/>
    </Profile>

    <!-- Two-line wrapping description text for settings like quality/dirtiness -->
    <Profile name="ueySettingDesc2Line" extends="fs25_textGrey" with="anchorTopLeft">
        <textSize value="13px"/>
        <textMaxNumLines value="2"/>
        <textVerticalAlignment value="top"/>
    </Profile>

    <!-- Small description text below a setting -->
    <Profile name="ueySettingDesc" extends="baseReference" with="anchorTopLeft">
        <textBold value="false"/>
        <textSize value="13px"/>
        <textAlignment value="left"/>
        <textColor value="0.8 0.8 0.8 0.5"/>
        <textWrap value="true"/>
    </Profile>

    <!-- Setting label (left side) -->
    <Profile name="ueySettingLabel" extends="baseReference" with="anchorTopLeft">
        <textBold value="false"/>
        <textSize value="17px"/>
        <textAlignment value="left"/>
        <textColor value="$preset_fs25_colorMainLight"/>
    </Profile>

    <!-- Weight row label (category name, right column) -->
    <Profile name="ueyWeightLabel" extends="baseReference" with="anchorTopLeft">
        <textBold value="false"/>
        <textSize value="15px"/>
        <textAlignment value="left"/>
        <textVerticalAlignment value="middle"/>
        <textColor value="$preset_fs25_colorMainLight"/>
    </Profile>

    <!-- MultiTextOption with top-left anchor for absolute positioning in our dialog -->
    <Profile name="ueyMultiTextOption" extends="fs25_settingsMultiTextOption" with="anchorTopLeft">
    </Profile>

    <!-- Weight row container inside ScrollingLayout -->
    <Profile name="ueyWeightRow" extends="baseReference" with="anchorTopLeft">
    </Profile>

    <!-- Generic top-left anchored container for absolute positioning -->
    <Profile name="ueySection" extends="baseReference" with="anchorTopLeft">
    </Profile>

</GUIProfiles>
