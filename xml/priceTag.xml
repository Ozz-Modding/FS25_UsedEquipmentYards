<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<!--
    Price tag plate definition for Used Equipment Yards.
    Uses the map's license plate font. 9 character slots for formatted prices.
-->
<licensePlates>
    <licensePlate filename="i3d/priceTag.i3d" node="0" type="ELONGATED"
                  width="0.52" height="0.11">
        <font size="0.07" scaleX="0.85" scaleY="1"/>

        <variations>
            <variation>
                <!-- 9 character slots, all accept digits + special (separators) -->
                <value node="0|0"  posX="-0.162" numerical="true" special="true"/>
                <value node="0|1"  posX="-0.108" numerical="true" special="true"/>
                <value node="0|2"  posX="-0.054" numerical="true" special="true"/>
                <value node="0|3"  posX="0.000"  numerical="true" special="true"/>
                <value node="0|4"  posX="0.054"  numerical="true" special="true"/>
                <value node="0|5"  posX="0.108"  numerical="true" special="true"/>
                <value node="0|6"  posX="0.162"  numerical="true" special="true"/>
            </variation>
        </variations>

        <frame node="2" widthOffset="0.005" heightOffsetTop="0.005" heightOffsetBot="0.015"/>
    </licensePlate>

    <colorConfigurations materialName="licensePlateColored_mat" useDefaultColors="false">
        <colorConfiguration name="White" color="1.0 1.0 1.0" isDefault="true"/>
    </colorConfigurations>

    <placement defaultType="both"/>
</licensePlates>
